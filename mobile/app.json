{
  "expo": {
    "name": "SwiftCare",
    "slug": "swiftcare",
    "version": "1.0.0",
    "orientation": "portrait",

    "icon": "./assets/icon.png",

    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "swiftcare",

    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.swiftcare.app"
    },

    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F5F7FA"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.swiftcare.app"
    },

    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },

    "plugins": [
      "expo-router",
      [
  "expo-splash-screen",
  {
    "image": "./assets/splash-icon.png",
    "imageWidth": 230,
    "resizeMode": "contain",
    "backgroundColor": "#E8F8F3"
  }
]
    ]
  }
}